{
  "manifest_version": 3,
  "name": "Text to Google Calendar",
  "version": "3.0",
  "description": "Select text on any webpage and instantly create Google Calendar events using AI.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "notifications",
    "identity"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
